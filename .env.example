APP_NAME=ConductorLedger
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/conductor-ledger/public
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_TIMEZONE=America/El_Salvador
APP_BASE_CURRENCY=USD
APP_DEFAULT_CURRENCY=USD

# CurrencyFreaks — https://currencyfreaks.com/documentation
# Plan gratuito: ~1000 llamadas/mes; 1 sync diario ≈ 30 llamadas/mes
CURRENCYFREAKS_API_KEY=
CURRENCYFREAKS_API_URL=https://api.currencyfreaks.com/v2.0/rates/latest
EXCHANGE_RATE_SYNC_MIN_HOURS=20

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=conductor_ledger
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
# Desarrollo Resend: usar onboarding@resend.dev (dominio verificado por Resend).
# Producción: verificar tu dominio en https://resend.com/domains y usar noreply@tudominio.com
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

REGISTRATION_MODE=approval
# En sandbox de Resend solo puedes enviar al correo de tu cuenta Resend hasta verificar dominio
SECURITY_ADMIN_EMAIL=tu-correo@gmail.com

MASTER_ENCRYPTION_KEY=
ENCRYPTION_KDF_MEMORY=65536
ENCRYPTION_KDF_TIME=4
ENCRYPTION_KDF_THREADS=1

BACKUP_DISK=backup_local
BACKUP_CLOUD_DISK=s3
BACKUP_RETENTION_MONTHS=12
BACKUP_NOTIFY_EMAIL=tu-correo@gmail.com
PG_DUMP_BINARY=pg_dump
# Windows (si pg_dump no está en PATH): ruta completa al binario de PostgreSQL
# PG_DUMP_BINARY="C:\Program Files\PostgreSQL\16\bin\pg_dump.exe"
# Linux/Docker: instale postgresql-client (apt) o use la ruta del contenedor
# Recomendado: habilitar extension=zip en php.ini; si no, Windows usa PowerShell y Linux el comando zip
BACKUP_DOWNLOAD_TOKEN_TTL=15

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
